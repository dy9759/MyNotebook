{
  "name": "sayso-notebook",
  "version": "0.1.0",
  "description": "SaySo Notebook - Desktop AI Research Assistant with Memory",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  },
  "build": {
    "appId": "com.sayso.notebook",
    "productName": "SaySo Notebook",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "zip"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ]
  }
}
